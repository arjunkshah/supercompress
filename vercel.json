{
  "buildCommand": "node scripts/inject-api-url.js",
  "outputDirectory": "web",
  "framework": null,
  "rewrites": [
    { "source": "/docs", "destination": "https://supercompress-api.fly.dev/docs" },
    { "source": "/v1/:path*", "destination": "https://supercompress-api.fly.dev/v1/:path*" },
    { "source": "/api/:path*", "destination": "https://supercompress-api.fly.dev/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
