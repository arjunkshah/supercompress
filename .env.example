# SuperCompress — copy to .env and add BuilderShip sponsor keys

# Nebius Token Factory (inference)
NEBIUS_API_KEY=
NEBIUS_MODEL=moonshotai/Kimi-K2.5

# Composio — github,gmail,slack,linear,notion,...
COMPOSIO_API_KEY=
HARBOR_USER_ID=supercompress-builder-001
COMPOSIO_TOOLKITS=github,gmail

# Tavily (search, extract, research)
TAVILY_API_KEY=

# Demo mode (1 = fixtures, no keys) | Live (0 + keys above)
HARBOR_DEMO=1

# Memory + agent loop
HARBOR_MEMORY_BUDGET=0.35
HARBOR_MAX_AGENT_TURNS=12

# Optional targets
GITHUB_OWNER=
GITHUB_REPO=
SLACK_CHANNEL_ID=
LINEAR_TEAM_ID=

# OpenClaw gateway (optional webhook bridge)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
